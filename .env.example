APP_NAME="MarkOnMinds"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=https://markonminds.com

# Public company branding (frontend header, SEO titles, schema — never MarkOnMinds).
MEDCA_BRAND_NAME="MarkOnMinds"
MEDCA_COMPANY_LEGAL_NAME="MarkOnMinds"

# After changing APP_URL on production, rewrite legacy *.test canonicals:
# php artisan medca:normalize-site-urls --to="${APP_URL}"

# Permanent root super administrator (case-insensitive email match). This account cannot be deleted or deactivated by others.
ROOT_SUPERADMIN_EMAIL=wdjerrie@markonminds.test

# User Management: comma-separated emails and/or display names that cannot be edited, toggled, or deleted (root account is excluded from this list).
USER_MANAGEMENT_PROFILE_READONLY_EMAILS=mail.webznetwork@gmail.com
USER_MANAGEMENT_PROFILE_READONLY_NAMES=MOMJERRIE
ARCHITECT_SAVE_BYPASS_NAMES=MOMJERRIE
MODULE_BUILDER_SCHEMA_MANAGER_NAMES=MOMJERRIE

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=markonminds
# DB_USERNAME=root
# DB_PASSWORD=

# Enterprise default: Redis (requires a running Redis server). Use "database" for zero-deps local SQLite setups.
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.medcahealthcare.in

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Use predis with QUEUE/CACHE/SESSION on redis (composer package predis/predis).
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="markonminds@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Optional CDN for public disk URLs (Media Library copy URLs). When false, APP_URL + /storage is used.
CDN_ENABLED=false
CDN_URL=

# Optional: initial admin user (see DatabaseSeeder). Leave empty to seed the default test user instead.
SEED_ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
# Never set true in production unless you intentionally need db:seed to reset the admin password.
ALLOW_SEED_ADMIN_PASSWORD_RESET=false

# Marketing: GA4 Data API (optional service account JSON path; falls back to GOOGLE_APPLICATION_CREDENTIALS)
MARKETING_GA4_CREDENTIALS_PATH=
MARKETING_GA4_CACHE_TTL=3600
MARKETING_GA4_DASHBOARD_URL=https://analytics.google.com/

# Marketing: Google Ads API (optional partial integration)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v18

# Marketing: Meta Marketing API (optional — insights only)
META_MARKETING_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Marketing Insights — optional Gemini narrative (also reads config/gemini.php)
GEMINI_API_KEY=

# Growth / AI Pulse — PageSpeed Insights API (mobile Lighthouse score 0–100; optional)
GOOGLE_PAGESPEED_API_KEY=
AI_PULSE_PAGESPEED_URL=
AI_PULSE_PAGESPEED_CACHE_TTL=21600
AI_PULSE_SPEED_BASELINE=72
AI_PULSE_SCHEDULE_DAILY=true

# Marketing GA4 insight thresholds (optional fine-tuning)
MARKETING_INSIGHT_CHANNEL_SHARE_WARN=0.62
MARKETING_INSIGHT_ENGAGEMENT_WARN_PCT=42

# Phase 11 — Marketing automation & attribution
MARKETING_AUTOMATION_ENABLED=true
MARKETING_ATTRIBUTION_ENABLED=true
MARKETING_CLICK_TRACKING_ENABLED=true
MARKETING_CLICK_RATE_LIMIT=120
MARKETING_ANALYTICS_CACHE_TTL=900
MARKETING_RETENTION_CLICK_EVENTS_DAYS=365
MARKETING_ATTRIBUTION_SESSIONS_ENABLED=true

# Exotel call tracking (POST /api/integrations/exotel/webhook)
EXOTEL_ENABLED=false
EXOTEL_ACCOUNT_SID=
EXOTEL_WEBHOOK_HMAC_SECRET=
EXOTEL_PRIMARY_EXOPHONE_SID=
EXOTEL_PRIMARY_PHONE_NUMBER=
EXOTEL_CALL_STITCH_WINDOW=120

# Sitemap cache + queue (Phases 6–7)
SITEMAP_CACHE_ENABLED=true
SITEMAP_QUEUE_ENABLED=true
SITEMAP_PAGINATED_ENABLED=true
SITEMAP_LOCATION_CHUNK_SIZE=10000

# Master Spec — public catalog meta cache (Wave 3+)
PUBLIC_CACHE_ENABLED=true
PUBLIC_CACHE_TTL=3600
# PUBLIC_CACHE_STORE=redis

# Google Search Console API (Growth Center GSC dashboard)
# Option A: static access token
MEDCA_GSC_ACCESS_TOKEN=
MEDCA_GSC_SITE_URL=
# Option B: OAuth refresh token (preferred; reuses Google Ads client if unset)
MEDCA_GSC_CLIENT_ID=
MEDCA_GSC_CLIENT_SECRET=
MEDCA_GSC_REFRESH_TOKEN=

# SEO ownership + data-driven SEO (Phases 8–9)
SEO_SKIP_AUTOFILL_GENERATED=true
SEO_SKIP_LOCATION_META_DUPLICATES=true
SEO_SKIP_PAGE_SEO_GENERATED=true
SEO_HIDE_EDITING_GENERATED=true
SEO_DATA_DRIVEN_ENABLED=true

# Post-launch tracking (applied via medca:post-launch-ops --activate-tracking)
MEDCA_GTM_CONTAINER_ID=
MEDCA_GA4_MEASUREMENT_ID=
MEDCA_GSC_VERIFICATION=
MEDCA_WHATSAPP_NUMBER="918593000360"

# Public lead ingest (POST /api/leads) — required; clients send header X-API-KEY
LEAD_API_KEY=

# API payment ingest — optional HMAC of raw JSON body (hex), header: X-Payment-Signature
SETTINGS_PAYMENT_INGEST_HMAC_SECRET=

# Sanctum SPA domains (comma-separated) when using cookie auth to same first-party API
SANCTUM_STATEFUL_DOMAINS=medcahealthcare.in,www.medcahealthcare.in,medcaeducation.in,www.medcaeducation.in
CAREERS_ORG_NAME="MarkOnMinds"
MEDCA_LOCATION="India"
MEDCA_PHONE_DISPLAY="+91 8593 000 360"
MEDCA_PHONE_TEL="+918593000360"
MEDCA_WHATSAPP_URL="https://wa.me/918593000360"

APP_NAME="MarkOnMinds"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Permanent root super administrator (case-insensitive email match). This account cannot be deleted or deactivated by others.
ROOT_SUPERADMIN_EMAIL=wdjerrie@markonminds.test

# User Management: comma-separated emails and/or display names that cannot be edited, toggled, or deleted (root account is excluded from this list).
USER_MANAGEMENT_PROFILE_READONLY_EMAILS=mail.webznetwork@gmail.com
USER_MANAGEMENT_PROFILE_READONLY_NAMES=WDJERRIE

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Optional CDN for public disk URLs (Media Library copy URLs). When false, APP_URL + /storage is used.
CDN_ENABLED=false
CDN_URL=

# Optional: initial admin user (see DatabaseSeeder). Leave empty to seed the default test user instead.
SEED_ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
